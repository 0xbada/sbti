<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title or "SBTI 테스트" }}</title>
  <meta name="description" content="{{ description or "MBTI 패러디 성격 테스트 — SBTI" }}">
  <link rel="canonical" href="https://sbti.funhada.xyz{{ page.url }}">

  <meta property="og:type" content="website">
  <meta property="og:url" content="https://sbti.funhada.xyz{{ page.url }}">
  <meta property="og:title" content="{{ ogTitle or title or "SBTI 테스트" }}">
  <meta property="og:description" content="{{ ogDescription or description or "MBTI 패러디 성격 테스트 — SBTI" }}">
  <meta property="og:image" content="https://sbti.funhada.xyz{{ ogImage or '/img/og-default.jpg' }}">
  <meta property="og:locale" content="ko_KR">
  <meta property="og:site_name" content="SBTI">

  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ ogTitle or title or "SBTI 테스트" }}">
  <meta name="twitter:description" content="{{ ogDescription or description or "MBTI 패러디 성격 테스트 — SBTI" }}">
  <meta name="twitter:image" content="https://sbti.funhada.xyz{{ ogImage or '/img/og-default.jpg' }}">

  <link rel="preload" href="/fonts/Paperlogy-4Regular.woff2" as="font" type="font/woff2" crossorigin>
  <link rel="preload" href="/fonts/Paperlogy-6SemiBold.woff2" as="font" type="font/woff2" crossorigin>
  <link rel="stylesheet" href="/css/base.css">
  {% if pageCss %}<link rel="stylesheet" href="/css/{{ pageCss }}.css">{% endif %}

  {% if site.analytics.gtmContainerId %}
  <script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
  new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
  j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
  'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
  })(window,document,'script','dataLayer','{{ site.analytics.gtmContainerId }}');</script>
  {% endif %}
  {% if site.analytics.ga4MeasurementId %}
  <script async src="https://www.googletagmanager.com/gtag/js?id={{ site.analytics.ga4MeasurementId }}"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', '{{ site.analytics.ga4MeasurementId }}', { anonymize_ip: true });
  </script>
  {% endif %}
</head>
<body>
  {% if site.analytics.gtmContainerId %}
  <noscript><iframe src="https://www.googletagmanager.com/ns.html?id={{ site.analytics.gtmContainerId }}"
    height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
  {% endif %}
  <main>
    {{ content | safe }}
  </main>
  {% if pageJs %}<script src="/js/{{ pageJs }}.js"></script>{% endif %}
</body>
</html>
