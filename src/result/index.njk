---
pagination:
  data: types
  size: 1
  alias: type
permalink: "/result/{{ type.slug }}/"
layout: layout.njk
pageCss: result
eleventyComputed:
  title: "{{ type.code }} · {{ type.nameKo }} — SBTI 결과"
  description: "{{ type.tagline }}"
  ogTitle: "내 SBTI 유형은 {{ type.code }} · {{ type.nameKo }}"
  ogDescription: "{{ type.tagline }}"
  ogImage: "{{ type.thumbnailPath }}"
---

<article class="result-page"
         data-type-code="{{ type.code }}"
         data-type-name-ko="{{ type.nameKo }}"
         data-type-tagline="{{ type.tagline }}"
         data-og-image="{{ type.thumbnailPath }}">
  <aside class="result-banner" id="result-banner" hidden aria-label="테스트 결과">
    <div class="result-banner-row">
      <span class="result-banner-label" id="banner-label">당신의 결과</span>
      <span class="result-banner-match" id="banner-match-rate"></span>
    </div>
    <p class="result-banner-note" id="banner-note"></p>
  </aside>

  <header class="result-header">
    <div class="result-code">{{ type.code }}</div>
    <p class="result-name">{{ type.nameKo }}</p>
    <p class="result-tagline">{{ type.tagline }}</p>
    <div class="result-badges">
      {% if type.rarity == "rare" %}<span class="result-badge result-badge--rare">희귀 유형</span>{% endif %}
      {% if type.rarity == "special" %}<span class="result-badge result-badge--special">특수 유형</span>{% endif %}
      {% if type.hidden %}<span class="result-badge result-badge--hidden">히든</span>{% endif %}
      {% if type.fallback %}<span class="result-badge result-badge--fallback">폴백</span>{% endif %}
    </div>
  </header>

  <section class="result-description">
    <p>{{ type.description }}</p>
  </section>

  <section class="result-profile" aria-label="15차원 성격 프로필">
    <h2 class="profile-heading">15차원 프로필</h2>
    {% for model in dimensions.models %}
      <div class="profile-model">
        <h3 class="profile-model-name">{{ model.nameKo }}</h3>
        {% for axis in model.axes %}
          {% set value = type.dimensionProfile[axis.code] %}
          {% set pct = (value * 100) | round %}
          <div class="profile-axis">
            <div class="profile-axis-label">
              <span class="profile-axis-name">{{ axis.nameKo }}</span>
              <span class="profile-axis-value">{{ pct }}%</span>
            </div>
            <div class="profile-axis-bar">
              <div class="profile-axis-fill" style="width: {{ pct }}%"></div>
            </div>
            <div class="profile-axis-poles">
              <span>{{ axis.lowLabel }}</span>
              <span>{{ axis.highLabel }}</span>
            </div>
          </div>
        {% endfor %}
      </div>
    {% endfor %}
  </section>

  <section class="result-share" aria-label="결과 공유">
    <p class="result-share-heading">결과를 친구에게 공유하기</p>
    <div class="share-buttons">
      <button type="button" class="share-btn share-btn--kakao" id="share-kakao">
        <span aria-hidden="true">💬</span> 카카오톡
      </button>
      <button type="button" class="share-btn" id="share-copy">
        <span aria-hidden="true">🔗</span> 링크 복사
      </button>
      <button type="button" class="share-btn" id="share-download">
        <span aria-hidden="true">⬇️</span> 이미지 저장
      </button>
    </div>
  </section>

  <section class="result-actions">
    <button type="button" class="cta" id="result-retry-btn">다시 테스트하기</button>
    <a href="/" class="result-link">홈으로</a>
  </section>

  <p class="result-disclaimer">엔터테인먼트 목적의 패러디 테스트입니다. 임상 심리 도구가 아닙니다.</p>
</article>

<script src="https://t1.kakaocdn.net/kakao_js_sdk/2.7.5/kakao.min.js"
        integrity="sha384-dok87au0gKqJdxs7msEdBPNnKSRT+/mhTVzq+qOhcL464zXwvcrpjeWvyj1kCdq6"
        crossorigin="anonymous"
        defer></script>
<script src="/js/result.js" defer></script>
<script src="/js/share.js" defer></script>
